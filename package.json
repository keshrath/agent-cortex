{
  "name": "agent-cortex",
  "version": "1.0.0",
  "description": "MCP server for AI agent memory and session recall — knowledge base + session transcript search with TF-IDF ranking",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-cortex": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "claude",
    "memory",
    "session-search",
    "tfidf",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
