{
  "name": "agent-cortex",
  "version": "1.0.0",
  "description": "MCP server for AI agent memory and session recall — knowledge base + session transcript search with TF-IDF ranking",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-cortex": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "keywords": [
    "mcp",
    "claude",
    "memory",
    "session-search",
    "tfidf",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.2"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
